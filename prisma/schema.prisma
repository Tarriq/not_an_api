generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "mysql"
}

model category {
  id          String          @id @default(uuid())
  name        String          @unique
  description String
  stories     storycategory[]
}

model save {

  userId    String
  storyId   String
  createdAt DateTime @default(now())
  story     story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, storyId])
  @@index([storyId], map: "save_storyId_fkey")
}

model story {
  id            String          @id @default(uuid())
  title         String
  borough       String
  content       String          @db.Text
  summary       String          @db.Text
  authorId      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now())
  thumbnail     String          @default("/media/its_in_motion.png")
  isPublished   Boolean         @default(false)
  isRadar       Boolean         @default(false)
  isRecommended Boolean         @default(false)
  isTrashed     Boolean         @default(false)
  save          save[]
  author        user            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categories    storycategory[]

  @@index([authorId], map: "story_authorId_fkey")
  @@index([isRadar, updatedAt(sort: Desc)])
  @@index([isRecommended, updatedAt(sort: Desc)])
}

model storycategory {
  storyId    String
  categoryId String
  category   category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  story      story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@id([storyId, categoryId])
  @@index([categoryId], map: "storycategory_categoryId_fkey")
}

model subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  phone     String?
}

model user {
  id            String    @id @unique @db.VarChar(255)
  firstName     String?   @db.VarChar(255)
  lastName      String?   @db.VarChar(255)
  email         String    @unique
  name          String?   @db.VarChar(255)
  emailVerified Boolean   @default(false)
  image         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now())
  role          String?   @default("user") @db.VarChar(255)
  accounts      account[]
  saves         save[]
  sessions      session[]
  stories       story[]
}

model session {
  id        String   @id @db.VarChar(255)
  expiresAt DateTime
  token     String   @unique(map: "token") @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  ipAddress String?  @db.VarChar(255)
  userAgent String?  @db.Text
  userId    String   @db.VarChar(255)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "session_userId_fkey")
}

model account {
  id                    String    @id @db.VarChar(255)
  accountId             String    @db.VarChar(255)
  providerId            String    @db.VarChar(255)
  userId                String    @db.VarChar(255)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "account_userId_fkey")
}

model verification {
  id         String    @id @db.VarChar(255)
  identifier String    @db.Text
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @default(now())
}
